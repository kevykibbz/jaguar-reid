# Azure Storage Configuration
# Get your connection string from Azure Portal:
# Storage Account > Access Keys > Connection String

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account_name;AccountKey=your_account_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=jaguar-images

# Azure PostgreSQL Database Configuration
# Format: postgresql://username:password@host:port/database
# Example: postgresql://jaguaruser:password@jaguar-db.postgres.database.azure.com:5432/jaguar_reid
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Optional: Database Configuration for local development
# DATABASE_TYPE=sqlite  # Options: sqlite, postgres
# DATABASE_PATH=./database  # For SQLite database
